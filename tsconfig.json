{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2022"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "outDir": "out",
    "sourceMap": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "mocha"]
  },
  "exclude": [
    "node_modules",
    "ca-lsp-server",
    ".vscode-test"
  ]
}